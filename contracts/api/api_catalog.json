    "semanticEnvelopeOwner": {
      "field": "semantic_envelope",
      "contractRef": "contracts/ui/page_surface_states.json#surfaceAuthorityContract.semanticEnvelope",
      "topLevelMirrorRule": "surface_state / surface_mode / surface_access top-level mirrors must equal semantic_envelope mirrors"
    },
    "fallbackReadModelRule": "persisted_typed_refs_then_formal_object_refs_then_operator_loop_fallback",
    "fallbackReviewPathRule": "missing formal refs => review-required; unresolved approval/audit => governed-hold; explicit policy/release block => blocked",
