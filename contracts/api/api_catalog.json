        "release_layer",
        "blocked_by_default",
        "live_execution_enabled",
        "route_local_booleans"
      ]
    },
    "governanceEnvelopeOwner": {
      "field": "governance_envelope",
      "actionAvailabilityRef": "contracts/ui/review_action_catalog.json#actionAvailabilityAuthority",
      "mustNotInferFrom": [
        "surface_state",
        "button_local_enabled_flags"
