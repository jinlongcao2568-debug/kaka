      "schedule_rules": [
        "if quiet_hours_policy_state=BLOCK => execution_compliance_decision=SCHEDULED and next_touch_due_at_optional = next allow window",
        "if frequency_policy_state=BLOCK => execution_compliance_decision=REVIEW_REQUIRED and plan_status=REVIEW_REQUIRED",
        "if execution_policy_state=APPROVAL_REQUIRED and run_mode in [APPROVAL_RUN,REAL_RUN] and approval_state!=APPROVED => execution_compliance_decision=REVIEW_REQUIRED",
        "if opt_out_state!=ACTIVE => execution_compliance_decision=BLOCKED and plan_status=BLOCKED"
      ]
    }
  ],
  "notes": [
    "Cadence is internal-only and must not be treated as external delivery capability.",
    "Scheduling must respect quiet hours and opt-out before any outreach execution.",
    "Cadence 只负责 execution scheduling，不得把 candidate_compliance_decision 从 ALLOW_PREVIEW 误降级成 BLOCKED。",
    "channel_ladders 只定义 governed preview 下的渠道梯度与 fallback 顺序，不表示自动切换成真实多渠道 live outreach。",
    "OUT-007 是 cadence_profile_id / retry_policy_id / stop_policy_id / channel ladder / fallback sequence 的唯一 machine-readable authority。"
  ]
