{
  "catalogVersion": "1.3.1",
  "catalogId": "opportunity_policy_catalog",
  "ownerDocs": [
    "D2",
    "D3",
    "D8",
    "D10",
    "D11"
  ],
  "stage6AuthoritativeInputContracts": {
    "contractId": "STAGE6-D8-AUTHORITY-001",
    "consumerObjects": [
      "saleable_opportunity",
      "sales_lead",
      "offer_recommendation",
      "buyer_fit",
      "challenger_buyer_fit"
    ],
    "fieldContracts": [
      {
        "field": "sale_gate_status",
        "authoritativeOwnerObject": "project_fact",
        "authoritativePath": "project_fact.sale_gate_status",
        "policyRef": "saleable_opportunity_generation_v1.requiredStates",
        "missingInputDecision": "REVIEW_REQUIRED",
        "reviewCarrierOrder": [
          "review_queue_profile",
          "report_record"
        ]
      },
      {
        "field": "competitor_quality_grade",
        "authoritativeOwnerObject": "project_fact",
        "authoritativePath": "project_fact.competitor_quality_grade",
        "policyRef": "competitor_confidence_catalog#STAGE6-COMPETITOR-GRADE-AUTHORITY-001",
        "missingInputDecision": "REVIEW_REQUIRED",
        "reviewCarrierOrder": [
          "review_queue_profile",
          "report_record",
          "challenger_candidate_profile"
        ]
      },
      {
        "field": "action_family",
        "authoritativeOwnerObject": "legal_action_recommendation",
        "authoritativePath": "legal_action_recommendation.action_family",
        "policyRef": "contracts/sales/stage6_legal_action_resolution_catalog.json#STAGE6-LAR-001",
        "missingInputDecision": "REVIEW_REQUIRED",
        "reviewCarrierOrder": [
          "review_queue_profile",
          "report_record"
        ]
      },
      {
        "field": "window_status",
        "authoritativeOwnerObject": "legal_action_recommendation",
        "authoritativePath": "legal_action_recommendation.window_status",
        "policyRef": "window_value_policy_catalog#WINDOW-STATUS-001",
        "missingInputDecision": "REVIEW_REQUIRED",
        "reviewCarrierOrder": [
          "review_queue_profile",
          "report_record"
        ]
      },
      {
        "field": "report_status",
        "authoritativeOwnerObject": "report_record",
        "authoritativePath": "report_record.report_status",
        "policyRef": "STATE-601~604",
        "missingInputDecision": "REVIEW_REQUIRED",
        "reviewCarrierOrder": [
          "report_record"
        ]
      },
      {
        "field": "review_task_status",
        "authoritativeOwnerObject": "report_record",
        "authoritativePath": "report_record.review_task_status",
        "policyRef": "STATE-601~604",
        "missingInputDecision": "REVIEW_REQUIRED",
        "reviewCarrierOrder": [
          "report_record"
        ]
      }
    ],
    "supportingNonAuthoritativeFields": [
      "project_fact.clue_summary",
      "project_fact.risk_summary"
    ],
    "consumerConstraint": "stage7_stage8_must_not_recompute",
    "forbiddenAuthoritativeSubstitutes": [
      "DEFAULT_CLUE",
      "DEFAULT_RISK",
      "heuristic competitor_quality_grade",
      "heuristic action_family"
    ]
  },
  "policies": [
    {
      "policyId": "saleable_opportunity_generation_v1",
      "targetObject": "saleable_opportunity",
      "requiredInputs": [
        "project_fact",
        "challenger_candidate_profile",
        "offer_recommendation",
        "buyer_fit or challenger_buyer_fit",
        "lead_value_scoring_catalog outputs",
        "buyer_fit_scorecard outputs",
        "sku_recommendation_policy outputs"
      ],
      "forbiddenInputs": [
        "single_rule_hit_only",
        "crm_note_only",
        "single_page_only",
        "free_text_why_recommended_override",
        "D_NON_PUBLIC_OR_FORENSIC direct input"
      ],
      "requiredStates": [
        "project_fact exists",
        "sale_gate_status != BLOCK",
        "rule_gate_status in [PASS,REVIEW]",
        "evidence_gate_status in [PASS,REVIEW]"
      ],
      "outputFields": [
        "opportunity_id",
        "project_id",
        "recommended_sku",
        "buyer_fit_id",
        "challenger_profile_id",
        "opportunity_grade",
        "saleability_status",
        "major_value_points",
        "blocking_reasons",
        "expected_close_days_band",
        "expected_contract_value_band",
        "expected_delivery_cost_band",
        "crm_owner_state",
        "opportunity_value_score_optional"
      ],
      "blockedWhen": [
        "project_root unresolved",
        "version or clock conflict unresolved",
        "coverage_sellable_state in [NOT_READY,SUSPENDED]",
        "delivery_risk_state=BLOCK"
      ]
    },
    {
      "policyId": "opportunity_outcome_writeback_v1",
      "targetObject": "opportunity_outcome_event",
      "requiredOutcomes": [
        "won",
        "lost",
        "window_missed",
        "contact_failed",
        "payer_mismatch",
        "false_positive",
        "delivery_abandoned"
      ],
      "mustWriteBackTo": [
        "sales_lead",
        "report_record"
      ],
      "mustWriteBackContractSemantics": "PROJECTED_MUTATION_ONLY",
      "mustAdvisoryWriteBackTo": [
        "buyer_fit",
        "challenger_candidate_profile"
      ],
      "mustAdvisoryWriteBackContractSemantics": "TRACE_ONLY_ADVISORY",
      "runtimeVisibilityFields": [
        "upstream_feedback_projected_targets",
        "upstream_feedback_advisory_targets",
        "writeback_target_contracts"
      ],
      "writebackRoleFields": {
        "projectedTargets": "mustWriteBackTo",
        "advisoryTargets": "mustAdvisoryWriteBackTo",
        "contractBundle": "upstreamFeedbackLoopContracts",
        "resolvedRuntimeFields": [
          "upstream_feedback_projected_targets",
          "upstream_feedback_advisory_targets",
          "resolved_effective_writeback_targets"
        ],
        "legacyRuntimeFieldsUnaffected": [
          "outcome_writeback_targets",
          "effective_writeback_targets"
        ]
      },
      "upstreamFeedbackLoopContracts": {
        "window_missed": {
          "projectedContractSemantics": "PROJECTED_MUTATION_ONLY",
          "advisoryContractSemantics": "TRACE_ONLY_ADVISORY",
          "directPersistenceForbidden": true,
          "projectedOnlyTargets": {
            "sales_lead": {
              "fieldPatches": {
                "lead_status": "REVIEW"
              },
              "effectSummary": "window missed requires lead re-qualification"
            },
            "report_record": {
              "fieldPatches": {
                "report_status": "REVIEW_REQUIRED"
              },
              "effectSummary": "window missed marks report output stale"
            }
          },
          "advisoryTargets": {
            "buyer_fit": {
              "fieldPatches": {
                "fit_refresh_required": true,
                "fit_refresh_reason": "WINDOW_MISSED"
              },
              "effectSummary": "window urgency change requires buyer fit refresh"
            }
          }
        },
        "contact_failed": {
          "projectedContractSemantics": "PROJECTED_MUTATION_ONLY",
          "advisoryContractSemantics": "TRACE_ONLY_ADVISORY",
          "directPersistenceForbidden": true,
          "projectedOnlyTargets": {
            "sales_lead": {
              "fieldPatches": {
                "lead_status": "REVIEW"
              },
              "effectSummary": "contact failure reopens lead qualification"
            },
            "report_record": {
              "fieldPatches": {
                "report_status": "REVIEW_REQUIRED"
              },
              "effectSummary": "contact failure requires report follow-up refresh"
            }
          },
          "advisoryTargets": {}
        },
        "false_positive": {
          "projectedContractSemantics": "PROJECTED_MUTATION_ONLY",
          "advisoryContractSemantics": "TRACE_ONLY_ADVISORY",
          "directPersistenceForbidden": true,
          "projectedOnlyTargets": {
            "sales_lead": {
              "fieldPatches": {
                "lead_status": "DISQUALIFIED"
              },
              "effectSummary": "false positive disqualifies current lead projection"
            },
            "report_record": {
              "fieldPatches": {
                "report_status": "REVIEW_REQUIRED"
              },
              "effectSummary": "false positive invalidates current report conclusion"
            }
          },
          "advisoryTargets": {
            "buyer_fit": {
              "fieldPatches": {
                "fit_refresh_required": true,
                "fit_refresh_reason": "FALSE_POSITIVE"
              },
              "effectSummary": "false positive requires buyer fit re-score"
            },
            "challenger_candidate_profile": {
              "fieldPatches": {
                "profile_refresh_required": true,
                "profile_refresh_reason": "FALSE_POSITIVE"
              },
              "effectSummary": "false positive requires challenger profile refresh"
            }
          }
        },
        "payer_mismatch": {
          "projectedContractSemantics": "PROJECTED_MUTATION_ONLY",
          "advisoryContractSemantics": "TRACE_ONLY_ADVISORY",
          "directPersistenceForbidden": true,
          "projectedOnlyTargets": {
            "sales_lead": {
              "fieldPatches": {
                "lead_status": "REVIEW"
              },
              "effectSummary": "payer mismatch returns lead to governed review"
            },
            "report_record": {
              "fieldPatches": {
                "report_status": "REVIEW_REQUIRED"
              },
              "effectSummary": "payer mismatch requires refreshed report guidance"
            }
          },
          "advisoryTargets": {}
        },
        "delivery_abandoned": {
          "projectedContractSemantics": "PROJECTED_MUTATION_ONLY",
          "advisoryContractSemantics": "TRACE_ONLY_ADVISORY",
          "directPersistenceForbidden": true,
          "projectedOnlyTargets": {
            "sales_lead": {
              "fieldPatches": {
                "lead_status": "REVIEW"
              },
              "effectSummary": "delivery failure returns lead to governed review"
            },
            "report_record": {
              "fieldPatches": {
                "report_status": "REVIEW_REQUIRED"
              },
              "effectSummary": "delivery failure requires refreshed report guidance"
            }
          },
          "advisoryTargets": {}
        }
      }
    }
  ],
  "expectedBandPolicies": [
    {
      "policy_id": "OPPORTUNITY-BAND-001",
      "title": "Expected close and delivery cost band derivation",
      "inputs": [
        "window_status",
        "window_urgency_score",
        "opportunity_grade",
        "recommended_delivery_form",
        "price_band"
      ],
      "close_days_rules": [
        {
          "rule_id": "CLOSE-MISSED",
          "window_statuses": [
            "MISSED",
            "CLOSED"
          ],
          "expected_close_days_band": "MISSED_WINDOW",
          "decision_state": "REVIEW"
        },
        {
          "rule_id": "CLOSE-FAST",
          "window_statuses": [
            "ACTIONABLE"
          ],
          "window_urgency_score": {
            "gte": 80
          },
          "expected_close_days_band": "0-7D",
          "decision_state": "ALLOW"
        },
        {
          "rule_id": "CLOSE-STANDARD",
          "window_statuses": [
            "ACTIONABLE"
          ],
          "window_urgency_score": {
            "gte": 55,
            "lt": 80
          },
          "expected_close_days_band": "8-14D",
          "decision_state": "ALLOW"
        },
        {
          "rule_id": "CLOSE-LONG",
          "window_statuses": [
            "ACTIONABLE"
          ],
          "window_urgency_score": {
            "lt": 55
          },
          "expected_close_days_band": "15-30D",
          "decision_state": "ALLOW"
        },
        {
          "rule_id": "CLOSE-REVIEW",
          "expected_close_days_band": "REVIEW_REQUIRED",
          "decision_state": "REVIEW"
        }
      ],
      "delivery_cost_rules": [
        {
          "rule_id": "COST-HIGH-FORMS",
          "recommended_delivery_forms": [
            "OBJECTION_DRAFT",
            "SCORING_EVIDENCE_SET",
            "PERFORMANCE_TRACKING"
          ],
          "expected_delivery_cost_band": "HIGH",
          "decision_state": "ALLOW"
        },
        {
          "rule_id": "COST-MEDIUM-FORMS",
          "recommended_delivery_forms": [
            "EVIDENCE_PACK",
            "ANALYSIS_REPORT",
            "RISK_REPORT",
            "ORG_BEHAVIOR_SUMMARY"
          ],
          "expected_delivery_cost_band": "MEDIUM",
          "decision_state": "ALLOW"
        },
        {
          "rule_id": "COST-LOW-FORMS",
          "recommended_delivery_forms": [
            "PROJECT_BRIEF",
            "COMPETITION_SUMMARY"
          ],
          "expected_delivery_cost_band": "LOW",
          "decision_state": "ALLOW"
        },
        {
          "rule_id": "COST-REVIEW",
          "expected_delivery_cost_band": "CUSTOM",
          "decision_state": "REVIEW"
        }
      ],
      "whyRecommendedTemplateId": "WHY-RECOMMENDED-001",
      "whyRecommendedTemplate": "policy={policy};sku={sku};grade={grade};window={window};close_band={close_band};cost_band={cost_band};quote_band={quote_band}",
      "whyRecommendedFields": [
        "policy",
        "sku",
        "grade",
        "window",
        "close_band",
        "cost_band",
        "quote_band"
      ],
      "formalSinkProjection": {
        "project_value_score_optional": "lead_value_scoring_catalog#PROJECT-VALUE-001",
        "opportunity_value_score_optional": "lead_value_scoring_catalog#OPPORTUNITY-VALUE-001",
        "expected_close_days_band": "OPPORTUNITY-BAND-001.close_days_rules",
        "expected_delivery_cost_band": "OPPORTUNITY-BAND-001.delivery_cost_rules",
        "why_recommended": "OPPORTUNITY-BAND-001.whyRecommendedTemplate"
      },
      "sourceContract": {
        "contractId": "STAGE7-EXPECTED-BAND-SOURCE-CONTRACT-001",
        "scope": "expected_close_days_band, expected_delivery_cost_band, why_recommended",
        "bandPolicyRef": "expectedBandPolicies.OPPORTUNITY-BAND-001",
        "requiredRuntimeInputs": [
          "window_status",
          "window_urgency_score",
          "opportunity_grade",
          "recommended_delivery_form",
          "price_band"
        ],
        "outputProjection": {
          "saleable_opportunity.expected_close_days_band": "close_days_rules.expected_close_days_band",
          "saleable_opportunity.expected_delivery_cost_band": "delivery_cost_rules.expected_delivery_cost_band",
          "offer_recommendation.why_recommended": "whyRecommendedTemplate(policy, sku, grade, window, close_band, cost_band, quote_band)"
        },
        "forbiddenSubstitutes": [
          "inputs.expected_close_days_band",
          "inputs.expected_delivery_cost_band",
          "inputs.why_recommended",
          "service_local_unknown_band_default"
        ]
      },
      "outputFields": [
        "saleable_opportunity.expected_close_days_band",
        "saleable_opportunity.expected_delivery_cost_band",
        "offer_recommendation.why_recommended"
      ]
    }
  ],
  "notes": [
    "Expected bands are internal sales orchestration fields and do not create an external delivery promise.",
    "why_recommended must be generated from formal rule outputs; free-text override is forbidden in this batch.",
    "mustWriteBackTo is the canonical upstream projected-only target set; mustAdvisoryWriteBackTo is the canonical upstream advisory trace-only target set.",
    "upstreamFeedbackLoopContracts only describes projected-only and advisory writeback semantics for Stage9 feedback loops; it does not authorize direct persistence into Stage6/7 objects.",
    "Stage6 authoritative inputs consumed by D8 objects must come from the declared stage6AuthoritativeInputContracts; missing inputs force review-only handling rather than local default or heuristic reconstruction.",
    "DEFAULT_CLUE, DEFAULT_RISK, heuristic competitor_quality_grade, and heuristic action_family are forbidden as authoritative substitutes."
  ]
}
