{
  "policyVersion": "1.0.2",
  "policyId": "channel_vendor_execution_policy",
  "ownerDocs": [
    "D2",
    "D9",
    "D11"
  ],
  "capability_mode_vocabulary_ref": "contracts/release/runtime_policy_catalog.json#capability_mode_vocabulary",
  "policyStates": [
    {
      "state": "PREVIEW_ONLY",
      "meaning": "仅允许生成候选内容、计划预览或人工确认前的展示。"
    },
    {
      "state": "DRY_RUN",
      "meaning": "仅允许模拟执行与回执预留，不触发真实发送。"
    },
    {
      "state": "APPROVAL_REQUIRED",
      "meaning": "只允许进入审批前置态；审批未通过不得真实执行。"
    },
    {
      "state": "BLOCKED",
      "meaning": "当前阶段禁止真实执行，只保留角色与审计语义。"
    }
  ],
  "policyDefaults": {
    "default_open": false,
    "live_execution_enabled": false,
    "external_action_enabled": false,
    "direct_mutation_allowed": false,
    "live_execution_requires_separate_release_gate": true
  },
  "requiredTraceFields": [
    "vendor_id",
    "vendor_type",
    "vendor_role",
    "execution_trace_id",
    "vendor_response_ref",
    "fallback_vendor_id",
    "requires_manual_review"
  ],
  "stage8ExecutionBoundary": {
    "authorizedConsumerObjects": [
      "outreach_plan",
      "touch_record"
    ],
    "forbiddenConsumerObjects": [
      "contact_target",
      "saleable_opportunity"
    ],
    "previewPolicyStates": [
      "PREVIEW_ONLY",
      "DRY_RUN",
      "APPROVAL_REQUIRED",
      "BLOCKED"
    ],
    "approvalReservationStates": [
      "APPROVAL_REQUIRED"
    ],
    "blockedByDefault": true
  },
