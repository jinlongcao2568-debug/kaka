        "blocked"
      ],
      "defaultMode": "preview-only"
    },
    {
      "profileId": "stage8_governed_preview_surface",
      "defaultState": "draft-only",
      "repositoryBackedReadModel": true,
      "semanticEnvelopeFieldRefs": {
        "surfaceStateField": "semantic_envelope.surface_state",
        "surfaceModeField": "semantic_envelope.surface_mode",
        "surfaceAccessField": "semantic_envelope.surface_access"
      },
      "capabilityDefaults": {
        "surfaceCapabilityMode": "INTERNAL_GOVERNED",
        "formalizationScope": "INTERNAL_GOVERNED",
        "internalOnly": true,
        "blockedByDefault": true,
        "liveExecutionEnabled": false
      },
      "fallbackReadModel": "persisted_typed_refs_then_formal_object_refs_then_operator_loop_fallback",
      "fallbackReviewPath": {
        "onMissingFormalRefs": "review-required",
        "onApprovalOrAuditGap": "governed-hold",
        "onExplicitPolicyBlock": "blocked"
      },
      "redlines": [
        "draft-only",
        "blocked_by_default",
        "live_execution_enabled=false"
      ],
      "allowedStates": [
        "draft-only",
        "review-required",
        "blocked",
        "governed-hold"
      ],
      "defaultMode": "draft-only"
    },
    {
      "profileId": "stage9_internal_governed_surface",
      "defaultState": "draft-only",
      "repositoryBackedReadModel": true,
      "semanticEnvelopeFieldRefs": {
        "surfaceStateField": "semantic_envelope.surface_state",
        "surfaceModeField": "semantic_envelope.surface_mode",
        "surfaceAccessField": "semantic_envelope.surface_access"
      },
      "capabilityDefaults": {
        "surfaceCapabilityMode": "INTERNAL_GOVERNED",
        "formalizationScope": "INTERNAL_GOVERNED",
        "internalOnly": true,
        "blockedByDefault": true,
        "liveExecutionEnabled": false
      },
      "fallbackReadModel": "persisted_typed_refs_then_formal_object_refs_then_operator_loop_fallback",
      "fallbackReviewPath": {
        "onMissingFormalRefs": "review-required",
        "onApprovalOrAuditGap": "governed-hold",
        "onExplicitPolicyBlock": "blocked"
      },
      "redlines": [
        "draft-only",
        "internal-writeback-only",
        "blocked_by_default",
        "live_execution_enabled=false"
      ],
      "allowedStates": [
        "draft-only",
        "review-required",
        "blocked",
