{
  "contract_id": "BUSINESS-DIRECTION-STRATEGY-CONTRACT",
  "contract_version": 10,
  "purpose": "固定招投标分析产品的双线业务方向，避免后续开发把招标公告文件链路验证误当成核心商业主线。",
  "primary_commercial_line": "POST_CANDIDATE_EVIDENCE_PACK",
  "default_when_ambiguous": "POST_CANDIDATE_EVIDENCE_PACK",
  "human_direction_priority": true,
  "customer_visible_allowed": false,
  "no_legal_conclusion": true,
  "product_lines": [
    {
      "line_id": "POST_CANDIDATE_EVIDENCE_PACK",
      "line_title": "候选公示后证据包分析",
      "business_priority": "PRIMARY",
      "default_entry_document_kinds": [
        "candidate_notice"
      ],
      "related_non_default_entry_document_kinds": [
        "evaluation_result",
        "opening_record",
        "award_result",
        "award_info",
        "failed_bid_notice"
      ],
      "required_backtrace_document_kinds": [
        "tender_notice",
        "tender_file",
        "qualification_pre_review",
        "clarification_or_addendum",
        "opening_record",
        "evaluation_result",
        "candidate_notice",
        "award_result",
        "bid_file_publicity",
        "rejection_reason_notice",
        "contract_public_info",
        "project_exception"
      ],
      "recent_candidate_late_stage_policy": {
        "flow_11_contract_public_info_required_for_current_sales_window": false,
        "flow_12_project_exception_required_for_current_sales_window": false,
        "notes": "近期 07 中标候选人公示项目通常尚未产生 11 合同信息公开和 12 项目异常；缺 11/12 不阻断当前候选后证据包销售窗口。若 11/12 已出现，应标记为历史/后期核验或复盘材料。"
      },
      "business_outputs": [
        "tailored_bid_signal",
        "collusion_trace_signal",
        "cover_bid_signal",
        "bid_rigging_signal",
        "candidate_verification",
        "real_competitor_identification",
        "violation_clue_evidence_pack",
        "sales_leadpack_handoff"
      ],
      "must_not_output": [
        "已内定",
        "违法成立",
        "控标成立",
        "必然废标"
      ]
    },
    {
      "line_id": "PRE_BID_PREDICTION",
      "line_title": "投前预测分析",
      "business_priority": "SECONDARY",
      "default_entry_document_kinds": [
        "tender_file_publicity",
        "tender_notice",
        "clarification_or_addendum"
      ],
      "required_backtrace_document_kinds": [
        "tender_notice",
        "tender_file",
        "clarification_or_addendum",
        "qualification_pre_review"
      ],
      "business_outputs": [
        "tailored_bid_prediction",
        "fatal_rejection_risk",
        "bid_selection_advice",
        "clarification_or_challenge_suggestion",
        "document_completeness_gap"
      ],
      "must_not_output": [
        "candidate_verification",
        "real_competitor_conclusion",
        "cover_bid_group_conclusion",
        "successful_bidder_benefit_chain"
      ]
    }
  ],
  "source_policy": {
    "primary_friendly_sources": [
      {
        "region_code": "CN-GD",
        "source_profile_id": "GUANGZHOU-YWTB-CONSTRUCTION-LIST",
        "source_title": "广州交易集团/广州公共资源交易中心建设工程源",
        "notes": "广东主源；支持广州 Epoint 附件挑战下载。"
      },
      {
        "region_code": "CN-ZJ",
        "source_profile_id": "ZHEJIANG-GGZY-JYXXGK-LIST",
        "source_title": "浙江公共资源交易源",
        "notes": "浙江独立适配。"
      },
      {
        "region_code": "CN-SC",
        "source_profile_id": "SICHUAN-GGZY-TRANSACTION-INFO",
        "source_title": "四川公共资源交易源",
        "notes": "四川独立适配。"
      }
    ],
    "observation_policy": "除广东广州、浙江、四川以外的省市，默认先做省源/市源完整性分析，再决定独立适配。"
  },
  "routing_rules": [
    {
      "rule_id": "BDR-001",
      "condition": "用户或任务涉及 07 中标候选人公示、候选人核查、真实竞争者、证据包、销售承接，默认从近期 07 入池并回溯同一项目全流程；评标结果、开标记录、中标结果属于回溯或支撑阶段，不是默认入口。",
      "route_to": "POST_CANDIDATE_EVIDENCE_PACK"
    },
    {
      "rule_id": "BDR-002",
      "condition": "用户或任务涉及 02 招标文件公示、03 招标公告/关联公告、04 澄清答疑、是否值得投、投前预测、澄清/质疑，且未出现 05 开标信息、07 中标候选人公示且截止/开标未过。",
      "route_to": "PRE_BID_PREDICTION"
    },
    {
      "rule_id": "BDR-003",
      "condition": "任务目标不明确但属于控标/围标/串标/陪标证据包方向",
      "route_to": "POST_CANDIDATE_EVIDENCE_PACK"
    }
  ],
  "analysis_strategy_policy": {
    "policy_id": "ANALYSIS-STRATEGY-PLAN-V1",
    "policy_version": 1,
    "required_before_download_or_parse": true,
    "purpose": "在附件清单之后、下载和解析之前，按产品线决定流程范围、文件动作、解析深度、规则核验和大模型触发条件，避免所有文件默认全量解析。",
    "routing_order": [
      {
        "order": 1,
        "condition": "flow_07_candidate_notice_present",
        "product_mode": "POST_CANDIDATE_EVIDENCE_PACK",
        "state": "POST_CANDIDATE_READY"
      },
      {
        "order": 2,
        "condition": "flow_05_opening_info_present_without_flow_07",
        "product_mode": "POST_OPENING_EVIDENCE_TRACK",
        "state": "PRE_BID_NOT_ELIGIBLE_OPENING_STARTED"
      },
      {
        "order": 3,
        "condition": "only_flow_02_03_04_present_and_deadline_not_passed",
        "product_mode": "PRE_BID_PREDICTION",
        "state": "PRE_BID_ELIGIBLE"
      },
      {
        "order": 4,
        "condition": "only_flow_02_03_04_present_but_deadline_or_opening_passed",
        "product_mode": "POST_OPENING_EVIDENCE_TRACK",
        "state": "PRE_BID_NOT_ELIGIBLE_DEADLINE_PASSED"
      },
      {
        "order": 5,
        "condition": "only_flow_01_or_early_plan_present",
        "product_mode": "WATCHLIST_ONLY",
        "state": "WATCHLIST_ONLY"
      }
    ],
    "pre_bid_hard_blockers": [
      {
        "blocker_id": "PRE_BID_NOT_ELIGIBLE_OPENING_STARTED",
        "condition": "flow_05_opening_info_present",
        "route_to": "POST_OPENING_EVIDENCE_TRACK"
      },
      {
        "blocker_id": "PRE_BID_NOT_ELIGIBLE_DEADLINE_PASSED",
        "condition": "bid_deadline_or_opening_time_passed",
        "route_to": "POST_OPENING_EVIDENCE_TRACK"
      },
      {
        "blocker_id": "PRE_BID_NOT_ELIGIBLE_CANDIDATE_PRESENT",
        "condition": "flow_07_candidate_notice_present",
        "route_to": "POST_CANDIDATE_EVIDENCE_PACK"
      }
    ],
    "pre_bid_time_window_policy": [
      {
        "state": "PRE_BID_STANDARD_PREDICTION_READY",
        "min_hours_to_bid_deadline_or_opening": 168,
        "commercial_action": "STANDARD_PRE_BID_PREDICTION_SALE_ALLOWED",
        "notes": "7天以上才适合作为标准投前预测销售窗口。"
      },
      {
        "state": "PRE_BID_LIMITED_FAST_REVIEW",
        "min_hours_to_bid_deadline_or_opening": 72,
        "max_hours_to_bid_deadline_or_opening_exclusive": 168,
        "commercial_action": "LIMITED_FAST_RISK_SCAN_ONLY",
        "notes": "3-7天只适合快速风险扫描和紧急建议，不包装成完整投前预测。"
      },
      {
        "state": "PRE_BID_NOT_ELIGIBLE_TOO_LATE_FOR_SALE",
        "max_hours_to_bid_deadline_or_opening_exclusive": 72,
        "commercial_action": "DO_NOT_SELL_PRE_BID_PREDICTION",
        "notes": "少于72小时通常来不及完成投前预测销售、客户决策、澄清质疑和投标文件准备。"
      }
    ],
    "default_source_time_window_policy": {
      "website_default_recent_first": true,
      "default_recent_window_unit": "WORKING_HOURS",
      "default_recent_working_hours": 72,
      "default_recent_window_state": "RECENT_72_WORKING_HOURS",
      "explicit_time_window_filter_planned": true,
      "planned_time_window_options_days": [
        1,
        3,
        7,
        15,
        30
      ],
      "notes": "两条业务入口默认只抓工作日 72 小时内的近期公告：07 用于候选后证据包，02/03/04 用于投前预测。30 天或更长窗口只用于广州 01-12 流程接口覆盖、历史适配验证或人类明确指定的回溯/历史场景。"
    },
    "pre_bid_clarification_recalculation_policy": {
      "before_flow_04_state": "PREDICTION_BEFORE_CLARIFICATION",
      "after_flow_04_state": "PREDICTION_AFTER_CLARIFICATION",
      "new_flow_04_or_supplement_state": "PREDICTION_RECALC_REQUIRED",
      "notes": "只有 02/03 而尚无 04 澄清答疑时，投前预测只能视为半成品/预澄清预测；后续出现澄清、答疑、补遗或补充招标文件时，必须重新下载相关文件并二次预测。"
    },
    "post_candidate_late_stage_policy": {
      "recent_candidate_default_entry_flow_no": "07",
      "flow_11_contract_public_info_absent_expected_for_recent_candidate": true,
      "flow_12_project_exception_absent_expected_for_recent_candidate": true,
      "late_stage_present_state": "HISTORICAL_OR_LATE_STAGE_REVIEW",
      "notes": "近期 07 中标候选人公示项目通常不会有 11 合同和 12 异常；缺失不算回溯失败，也不阻断当前可售证据窗口。若 11/12 已出现，通常说明项目进入后期或历史复盘，销售窗口需另判。"
    },
    "responsible_person_early_probe_policy": {
      "policy_id": "RESPONSIBLE-PERSON-EARLY-PROBE-V1",
      "policy_version": 1,
      "required_before_stage4_live_verification": true,
      "applies_to_product_mode": "POST_CANDIDATE_EVIDENCE_PACK",
      "purpose": "在候选后证据包路线中，以最低解析成本尽早取得候选公司、项目负责人/总监/设计负责人、证书号、报价和排名；拿到证书号即可先进入 Stage4 核验，未拿到再逐层加深解析。",
      "candidate_group_binding_policy": {
        "must_bind_by_candidate_row": true,
        "candidate_group_fields": [
          "candidate_group_id",
          "candidate_group_order",
          "candidate_group_members",
          "responsible_person_name",
          "certificate_no",
          "bid_price",
          "rank"
        ],
        "consortium_member_policy": "VERIFY_ALL_MEMBERS_AS_ALTERNATIVE_REGISTERED_UNIT_TARGETS",
        "group_resolution_rule": "ANY_CONSORTIUM_MEMBER_MATCH_RESOLVES_THE_CANDIDATE_GROUP",
        "must_not": [
          "do_not_cross_match_company_person_certificate_between_candidate_rows",
          "do_not_only_verify_consortium_lead_company",
          "do_not_escalate_nonmatched_member_when_same_candidate_group_has_matched_member"
        ],
        "notes": "07 多候选人公示必须先按候选行形成候选组；同一候选组内联合体牵头方和成员方全部进入核验目标。负责人/证书只能绑定同一候选行；同组任一成员匹配注册单位即可认为该候选组身份线索已解析。"
      },
      "preferred_evidence_order": [
        {
          "order": 1,
          "flow_no": "07",
          "source": "candidate_notice_detail_html",
          "action": "RULE_PARSE_ONLY",
          "stop_when_fields_present": [
            "candidate_company",
            "responsible_person_name",
            "certificate_no"
          ]
        },
        {
          "order": 2,
          "flow_no": "07",
          "source": "candidate_notice_small_pdf_or_evaluation_report_pdf",
          "action": "MARKITDOWN_TEXT_PROBE_THEN_RULE_PARSE",
          "preferred_file_name_keywords": [
            "中标候选人公示",
            "定标候选人公示",
            "评标报告",
            "复评报告"
          ],
          "stop_when_fields_present": [
            "candidate_company",
            "responsible_person_name",
            "certificate_no"
          ]
        },
        {
          "order": 3,
          "flow_no": "07",
          "source": "candidate_notice_scanned_pdf",
          "action": "OCR_ONLY_WHEN_MARKITDOWN_TEXT_EMPTY_AND_TARGET_FIELDS_MISSING"
        },
        {
          "order": 4,
          "flow_no": "08",
          "source": "bid_file_publicity",
          "action": "TARGETED_PARSE_ONLY",
          "preferred_file_name_keywords": [
            "资格",
            "项目负责人",
            "项目经理",
            "总监",
            "建造师",
            "证书",
            "商务",
            "投标函"
          ],
          "notes": "08 先全量登记清单；只有 07 和 Stage4 补证不足时才定向解析，不默认全量深解析。"
        }
      ],
      "stage4_supplement_decision_tree": [
        {
          "state": "CERTIFICATE_READY_FROM_07",
          "condition": "flow_07_has_candidate_company_responsible_person_and_certificate_no",
          "next_action": "STAGE4_VERIFY_CERTIFICATE_AND_REGISTERED_UNIT"
        },
        {
          "state": "COMPANY_FIRST_CERTIFICATE_SUPPLEMENT_REQUIRED",
          "condition": "flow_07_has_candidate_company_and_responsible_person_but_no_certificate_no",
          "next_action": "QUERY_CANDIDATE_COMPANY_PERSONNEL_LIST_THEN_WRITE_BACK_CERTIFICATE_NO"
        },
        {
          "state": "NAME_ENUMERATION_FALLBACK_REQUIRED",
          "condition": "company_first_does_not_find_unique_person_match",
          "next_action": "ENUMERATE_PUBLIC_PERSONS_BY_NAME_UNTIL_REGISTERED_UNIT_MATCHES_CANDIDATE_COMPANY_OR_JOINT_VENTURE_MEMBER"
        },
        {
          "state": "FLOW_08_TARGETED_PARSE_REQUIRED",
          "condition": "company_first_and_name_enumeration_do_not_find_matching_company",
          "next_action": "ESCALATE_RISK_AND_PARSE_FLOW_08_TARGET_FILES_FOR_CERTIFICATE_NO"
        },
        {
          "state": "STRONG_CONFLICT_CLUE_AFTER_08",
          "condition": "flow_08_certificate_no_found_but_registered_unit_still_does_not_match_candidate_company_or_joint_venture_member",
          "next_action": "RAISE_PERSON_COMPANY_MISMATCH_RISK_AND_SEND_TO_STAGE5_EVIDENCE_GATE"
        },
        {
          "state": "INSUFFICIENT_EVIDENCE_AFTER_08",
          "condition": "flow_08_targeted_parse_still_has_no_certificate_no_or_replayable_text",
          "next_action": "KEEP_HIGH_RISK_REVIEW_AND_REQUIRE_OCR_OR_DEEPER_PARSE"
        }
      ],
      "risk_escalation_policy": {
        "company_first_no_match_risk": "HIGH_CLUE_REVIEW",
        "name_enumeration_no_registered_unit_match_risk": "HIGH_CLUE_REVIEW",
        "flow_08_certificate_registered_unit_mismatch_risk": "STRONG_CLUE_REVIEW",
        "must_not_treat_as_final_legal_conclusion": true,
        "allowed_internal_phrases": [
          "项目负责人注册单位不一致线索",
          "项目负责人公开注册信息未匹配候选公司",
          "需结合08投标文件公开进一步确认",
          "证书号回填后注册单位仍不一致，高风险线索"
        ],
        "forbidden_phrases": [
          "违法成立",
          "已内定",
          "必然废标",
          "冲突成立"
        ]
      },
      "must_not": [
        "do_not_deep_parse_all_flow_08_by_default",
        "do_not_treat_name_only_public_search_as_pass",
        "do_not_treat_company_first_no_match_as_final_conflict_without_flow_08_or_stage4_readback",
        "do_not_force_project_manager_role_for_insurance_or_non_engineering_service_projects"
      ]
    },
    "public_registration_match_and_conflict_probe_policy": {
      "policy_id": "PUBLIC-REGISTRATION-MATCH-AND-CONFLICT-PROBE-V1",
      "policy_version": 1,
      "applies_to_product_mode": "POST_CANDIDATE_EVIDENCE_PACK",
      "purpose": "把候选公示或 08 投标文件公开中的负责人字段，与四库/地方注册人员公开记录做公开注册信息匹配；不表述自然人本人核实。",
      "language_boundary": {
        "allowed_terms": [
          "公开注册信息匹配",
          "姓名与注册单位匹配",
          "证书号与公开注册记录匹配",
          "注册单位不一致线索",
          "证书类别或专业不一致线索"
        ],
        "forbidden_terms": [
          "是不是本人",
          "确认本人",
          "本人核实",
          "冲突成立",
          "造假成立"
        ]
      },
      "match_acceptance_policy": {
        "name_and_registered_unit_match_state": "PUBLIC_REGISTRATION_NAME_COMPANY_MATCHED",
        "certificate_and_registered_unit_match_state": "PUBLIC_REGISTRATION_CERTIFICATE_STRONG_MATCH",
        "group_resolution_rule": "同一候选组任一候选公司或联合体成员与公开注册单位匹配，即视为该候选组身份线索已解析。",
        "do_not_require_flow_08_when_flow_07_public_registration_match_succeeds": true
      },
      "field_checks": [
        "responsible_person_name",
        "candidate_company_or_consortium_member_name",
        "certificate_no",
        "registered_unit_name",
        "registration_category",
        "registration_profession",
        "certificate_validity_or_status",
        "registration_or_change_time"
      ],
      "route_order": [
        {
          "order": 1,
          "route_id": "PERSON_NAME_WITH_COMPANY_QUERY",
          "description": "用姓名 + 公司/注册单位直接查人员，作为默认最快路线。"
        },
        {
          "order": 2,
          "route_id": "COMPANY_SEARCH_THEN_PERSON_QUERY",
          "description": "先搜公司规范化企业名，再查企业人员列表或人员页。"
        },
        {
          "order": 3,
          "route_id": "PERSON_NAME_ONLY_FILTER_COMPANY",
          "description": "姓名-only 枚举公开人员，再按注册单位过滤，作为最后兜底。"
        }
      ],
      "flow_08_trigger_policy": {
        "default_parse_flow_08_for_certificate_check": false,
        "trigger_when": [
          "flow_07_missing_responsible_person_or_certificate_fields",
          "public_registration_record_not_matched_after_route_fallbacks",
          "certificate_no_or_registered_unit_conflicts_with_flow_07",
          "registration_category_or_profession_needed_for_role_rule",
          "declared_performance_in_flow_08_needs_public_record_match"
        ]
      },
      "performance_and_active_conflict_policy": {
        "jzsc_performance_usage": "ONLY_AS_AUXILIARY_PUBLIC_RECORD_MATCH_FOR_DECLARED_FLOW_08_PERFORMANCE",
        "jzsc_lagging_risk_acknowledged": true,
        "jzsc_not_unique_active_conflict_source": true,
        "active_conflict_priority_sources": [
          "local_public_resource_candidate_or_award_notices",
          "local_housing_construction_or_administrative_approval_platform",
          "construction_permit",
          "contract_filing",
          "completion_or_acceptance_filing",
          "project_manager_change_notice",
          "administrative_penalty_or_complaint_decision",
          "public_web_clues_with_replayable_source_url"
        ],
        "must_not": [
          "do_not_treat_jzsc_missing_project_as_no_active_conflict",
          "do_not_treat_jzsc_missing_performance_as_performance_fraud",
          "do_not_use_jzsc_as_realtime_active_conflict_single_source"
        ]
      }
    },
    "flow_08_registry_only_policy": {
      "policy_id": "FLOW-08-REGISTRY-ONLY-BY-DEFAULT-V1",
      "policy_version": 1,
      "default_download_policy": "REGISTER_ONLY_THEN_TARGETED_PARSE_IF_TRIGGERED",
      "default_parse_depth": "LIST_ONLY",
      "default_download_required": false,
      "default_parse_required": false,
      "must_record_fields": [
        "flow_08_present",
        "source_url",
        "published_date",
        "attachment_count",
        "attachment_names",
        "candidate_or_bidder_file_groups",
        "targeted_parse_candidate_keywords"
      ],
      "targeted_parse_trigger_when": [
        "flow_07_missing_responsible_person_or_certificate_fields",
        "public_registration_record_not_matched_after_route_fallbacks",
        "certificate_no_or_registered_unit_conflicts_with_flow_07",
        "registration_category_or_profession_needed_for_role_rule",
        "declared_performance_in_flow_08_needs_public_record_match"
      ],
      "must_not": [
        "do_not_download_all_flow_08_by_default",
        "do_not_parse_all_flow_08_by_default",
        "do_not_block_evidence_report_only_because_flow_08_exists_but_is_unparsed"
      ]
    },
    "active_conflict_external_source_policy": {
