{
  "contract_id": "BUSINESS-DIRECTION-STRATEGY-CONTRACT",
  "contract_version": 2,
  "purpose": "固定招投标分析产品的双线业务方向，避免后续开发把招标公告文件链路验证误当成核心商业主线。",
  "primary_commercial_line": "POST_CANDIDATE_EVIDENCE_PACK",
  "default_when_ambiguous": "POST_CANDIDATE_EVIDENCE_PACK",
  "human_direction_priority": true,
  "customer_visible_allowed": false,
  "no_legal_conclusion": true,
  "product_lines": [
    {
      "line_id": "POST_CANDIDATE_EVIDENCE_PACK",
      "line_title": "候选公示后证据包分析",
      "business_priority": "PRIMARY",
      "default_entry_document_kinds": [
        "candidate_notice",
        "evaluation_result",
        "opening_record",
        "award_result",
        "failed_bid_notice"
      ],
      "required_backtrace_document_kinds": [
        "tender_notice",
        "tender_file",
        "qualification_pre_review",
        "clarification_or_addendum",
        "opening_record",
        "evaluation_result",
        "candidate_notice",
        "award_result",
        "bid_file_publicity",
        "rejection_reason_notice"
      ],
      "business_outputs": [
        "tailored_bid_signal",
        "collusion_trace_signal",
        "cover_bid_signal",
        "bid_rigging_signal",
        "candidate_verification",
        "real_competitor_identification",
        "violation_clue_evidence_pack",
        "sales_leadpack_handoff"
      ],
      "must_not_output": [
        "已内定",
        "违法成立",
        "控标成立",
        "必然废标"
      ]
    },
    {
      "line_id": "PRE_BID_PREDICTION",
      "line_title": "投前预测分析",
      "business_priority": "SECONDARY",
      "default_entry_document_kinds": [
        "tender_notice",
        "tender_file",
        "procurement_intention",
        "tender_plan",
        "clarification_or_addendum"
      ],
      "required_backtrace_document_kinds": [
        "tender_notice",
        "tender_file",
        "clarification_or_addendum",
        "qualification_pre_review"
      ],
      "business_outputs": [
        "tailored_bid_prediction",
        "fatal_rejection_risk",
        "bid_selection_advice",
        "clarification_or_challenge_suggestion",
        "document_completeness_gap"
      ],
      "must_not_output": [
        "candidate_verification",
        "real_competitor_conclusion",
        "cover_bid_group_conclusion",
        "successful_bidder_benefit_chain"
      ]
    }
  ],
  "source_policy": {
    "primary_friendly_sources": [
      {
        "region_code": "CN-GD",
        "source_profile_id": "GUANGZHOU-YWTB-CONSTRUCTION-LIST",
        "source_title": "广州交易集团/广州公共资源交易中心建设工程源",
        "notes": "广东主源；支持广州 Epoint 附件挑战下载。"
      },
      {
        "region_code": "CN-ZJ",
        "source_profile_id": "ZHEJIANG-GGZY-JYXXGK-LIST",
        "source_title": "浙江公共资源交易源",
        "notes": "浙江独立适配。"
      },
      {
        "region_code": "CN-SC",
        "source_profile_id": "SICHUAN-GGZY-TRANSACTION-INFO",
        "source_title": "四川公共资源交易源",
        "notes": "四川独立适配。"
      }
    ],
    "observation_policy": "除广东广州、浙江、四川以外的省市，默认先做省源/市源完整性分析，再决定独立适配。"
  },
  "routing_rules": [
    {
      "rule_id": "BDR-001",
      "condition": "用户或任务涉及候选公示、评标结果、中标结果、候选人核查、真实竞争者、证据包、销售承接",
      "route_to": "POST_CANDIDATE_EVIDENCE_PACK"
    },
    {
      "rule_id": "BDR-002",
      "condition": "用户或任务涉及刚发布招标公告、招标文件、是否值得投、投前预测、澄清/质疑",
      "route_to": "PRE_BID_PREDICTION"
    },
    {
      "rule_id": "BDR-003",
      "condition": "任务目标不明确但属于控标/围标/串标/陪标证据包方向",
      "route_to": "POST_CANDIDATE_EVIDENCE_PACK"
    }
  ],
  "analysis_strategy_policy": {
    "policy_id": "ANALYSIS-STRATEGY-PLAN-V1",
    "policy_version": 1,
    "required_before_download_or_parse": true,
    "purpose": "在附件清单之后、下载和解析之前，按产品线决定流程范围、文件动作、解析深度、规则核验和大模型触发条件，避免所有文件默认全量解析。",
    "routing_order": [
      {
        "order": 1,
        "condition": "flow_07_candidate_notice_present_or_award_result_present",
        "product_mode": "POST_CANDIDATE_EVIDENCE_PACK",
        "state": "POST_CANDIDATE_READY"
      },
      {
        "order": 2,
        "condition": "flow_05_opening_info_present_without_flow_07",
        "product_mode": "POST_OPENING_EVIDENCE_TRACK",
        "state": "PRE_BID_NOT_ELIGIBLE_OPENING_STARTED"
      },
      {
        "order": 3,
        "condition": "only_flow_02_03_04_present_and_deadline_not_passed",
        "product_mode": "PRE_BID_PREDICTION",
        "state": "PRE_BID_ELIGIBLE"
      },
      {
        "order": 4,
        "condition": "only_flow_02_03_04_present_but_deadline_or_opening_passed",
        "product_mode": "POST_OPENING_EVIDENCE_TRACK",
        "state": "PRE_BID_NOT_ELIGIBLE_DEADLINE_PASSED"
      },
      {
        "order": 5,
        "condition": "only_flow_01_or_early_plan_present",
        "product_mode": "WATCHLIST_ONLY",
        "state": "WATCHLIST_ONLY"
      }
    ],
    "pre_bid_hard_blockers": [
      {
        "blocker_id": "PRE_BID_NOT_ELIGIBLE_OPENING_STARTED",
        "condition": "flow_05_opening_info_present",
        "route_to": "POST_OPENING_EVIDENCE_TRACK"
      },
      {
        "blocker_id": "PRE_BID_NOT_ELIGIBLE_DEADLINE_PASSED",
        "condition": "bid_deadline_or_opening_time_passed",
        "route_to": "POST_OPENING_EVIDENCE_TRACK"
      },
      {
        "blocker_id": "PRE_BID_NOT_ELIGIBLE_CANDIDATE_PRESENT",
        "condition": "flow_07_candidate_notice_present",
        "route_to": "POST_CANDIDATE_EVIDENCE_PACK"
      }
    ],
    "pre_bid_time_window_policy": [
      {
        "state": "PRE_BID_STANDARD_PREDICTION_READY",
        "min_hours_to_bid_deadline_or_opening": 168,
        "commercial_action": "STANDARD_PRE_BID_PREDICTION_SALE_ALLOWED",
        "notes": "7天以上才适合作为标准投前预测销售窗口。"
      },
      {
        "state": "PRE_BID_LIMITED_FAST_REVIEW",
        "min_hours_to_bid_deadline_or_opening": 72,
        "max_hours_to_bid_deadline_or_opening_exclusive": 168,
        "commercial_action": "LIMITED_FAST_RISK_SCAN_ONLY",
        "notes": "3-7天只适合快速风险扫描和紧急建议，不包装成完整投前预测。"
      },
      {
        "state": "PRE_BID_NOT_ELIGIBLE_TOO_LATE_FOR_SALE",
        "max_hours_to_bid_deadline_or_opening_exclusive": 72,
        "commercial_action": "DO_NOT_SELL_PRE_BID_PREDICTION",
        "notes": "少于72小时通常来不及完成投前预测销售、客户决策、澄清质疑和投标文件准备。"
      }
    ],
    "parse_depth_levels": [
      "NONE",
      "METADATA_ONLY",
      "LIST_ONLY",
      "TEXT_PROBE",
      "SECTION_PARSE",
      "DEEP_PARSE"
    ],
    "post_candidate_flow_policy": [
      {
        "flow_no": "03",
        "flow_title": "招标公告/关联公告",
        "download_policy": "DOWNLOAD_REQUIRED",
        "parse_depth": "SECTION_PARSE",
        "index_targets": [
          "tailored_bid_index",
          "fatal_rejection_complexity_index"
        ]
      },
      {
        "flow_no": "04",
        "flow_title": "澄清答疑",
        "download_policy": "DOWNLOAD_REQUIRED",
        "parse_depth": "SECTION_PARSE",
        "index_targets": [
          "tailored_bid_index",
          "procedure_abnormality_index"
        ]
      },
      {
        "flow_no": "05",
        "flow_title": "开标信息",
        "download_policy": "LIST_OR_DOWNLOAD_IF_ATTACHMENT_PRESENT",
        "parse_depth": "TEXT_PROBE",
        "index_targets": [
          "collusion_trace_index",
          "cover_bid_index",
          "bid_rigging_index"
        ]
      },
      {
        "flow_no": "06",
        "flow_title": "资审结果公示",
        "download_policy": "LIST_OR_DOWNLOAD_IF_ATTACHMENT_PRESENT",
        "parse_depth": "TEXT_PROBE",
        "index_targets": [
          "fatal_rejection_complexity_index",
          "real_competitor_identification"
        ]
      },
      {
        "flow_no": "07",
        "flow_title": "中标候选人公示",
        "download_policy": "DOWNLOAD_REQUIRED_IF_ATTACHMENT_PRESENT",
        "parse_depth": "TEXT_PROBE",
        "index_targets": [
          "candidate_verification",
          "real_competitor_identification",
          "sales_leadpack_handoff"
        ]
      },
      {
        "flow_no": "08",
        "flow_title": "投标文件公开",
        "download_policy": "LIST_ALL_THEN_TARGETED_DOWNLOAD",
        "parse_depth": "TEXT_PROBE_THEN_TARGETED_DEEP_PARSE",
        "index_targets": [
          "collusion_trace_index",
          "cover_bid_index",
          "bid_rigging_index",
          "real_competitor_identification"
        ]
      }
    ],
    "pre_bid_flow_policy": [
      {
        "flow_no": "02",
        "flow_title": "招标文件公示",
        "download_policy": "DOWNLOAD_REQUIRED_IF_DOCUMENT_PRESENT",
        "parse_depth": "SECTION_PARSE"
      },
      {
        "flow_no": "03",
        "flow_title": "招标公告/关联公告",
        "download_policy": "DOWNLOAD_REQUIRED",
        "parse_depth": "SECTION_PARSE"
      },
      {
        "flow_no": "04",
        "flow_title": "澄清答疑",
        "download_policy": "DOWNLOAD_REQUIRED_IF_PRESENT",
        "parse_depth": "SECTION_PARSE"
      }
    ],
    "llm_trigger_policy": {
      "rules_first": true,
      "trigger_when": [
        "high_tailored_or_collusion_index",
        "bidder_response_conflicts_with_tender_file",
        "multiple_bid_files_high_similarity",
        "abnormal_quote_pattern_requires_context",
        "rejection_reason_conflicts_with_document_rules",
        "parameter_or_certificate_reasonableness_requires_context"
      ],
      "do_not_trigger_for": [
        "metadata_only_without_text",
        "non_tender_document_guardrail_hit",
        "missing_replayable_snapshot",
        "adapter_validation_url_only"
      ]
    },
    "adapter_validation_policy": {
      "guangzhou_12_flow_samples_are_adapter_validation_only": true,
      "human_provided_flow_urls_default_crawl_target_allowed": false,
      "human_provided_flow_urls_production_crawl_source_allowed": false,
      "production_crawl_must_use": [
        "list_api",
        "flow_code",
        "relationInfo",
        "project_id_or_xmbh",
        "normalized_project_name"
      ]
    }
  },
  "project_level_audit_required_fields": [
    "project_id",
    "project_name",
    "source_urls",
    "verification_urls",
    "verification_urls.all_urls",
    "file_inventory",
    "detail_file_count",
    "attachment_file_count",
    "replayable_file_count",
    "parsed_file_count",
    "download_completeness_state",
    "parse_completeness_state",
    "failure_reasons",
    "post_candidate_entry_state",
    "backtrace_stage_attempts",
    "matched_project_keys",
    "missing_stage_kinds",
    "backtrace_completeness_state",
    "ready_for_tailored_analysis"
  ],
  "run_modes": [
    {
      "run_mode_id": "GUANGZHOU_TENDER_FILE_SMOKE",
      "line_id": "PRE_BID_PREDICTION",
      "script": "scripts/run-professional-clean-v1-real-samples.ps1",
      "status": "AVAILABLE",
      "purpose": "仅验证广州招标公告文件链路、Epoint 挑战下载、snapshot 和解析，不代表核心商业入口。"
    },
    {
      "run_mode_id": "THREE_PROVINCE_CLEAN_V1_SMOKE",
      "line_id": "PRE_BID_PREDICTION",
      "script": "scripts/run-professional-clean-v1-real-samples.ps1",
      "status": "AVAILABLE",
      "purpose": "验证广东广州、浙江、四川文件下载/解析/项目审计链路。"
    },
    {
      "run_mode_id": "POST_CANDIDATE_BACKTRACE_V1",
      "line_id": "POST_CANDIDATE_EVIDENCE_PACK",
      "script": "scripts/run-guangzhou-post-candidate-backtrace-v1.ps1",
      "status": "AVAILABLE",
      "purpose": "广州候选公示后证据包入口：从候选公示/中标结果入池，按同项目回溯核心阶段，生成项目级证据链审计和挑战稳定性报告。"
    }
  ],
  "analysis_boundaries": [
    "样本数量必须以 project_id 和可 replay 文件完整率为核心，不用目标桶数量冒充项目数量。",
    "招标公告 smoke 只证明文件链路，不代表候选公示后证据包主线完成。",
    "投前预测线不能生成候选人核查、真实竞争者结论或陪标组合结论。",
    "候选公示后证据包线必须回溯招标文件、答疑澄清、开标、候选、结果和投标文件公开等全过程材料。",
    "所有真实文件必须下载到本地对象仓库并通过 replay_snapshot 后才进入解析和证据包。"
  ]
}
