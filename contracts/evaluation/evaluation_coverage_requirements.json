        "technical_scored",
        "bid_separation"
      ],
      "basis_refs": [
        "BASIS-EVALUATION-METHODS",
        "LOCAL-GD-EVALUATION-GUIDE",
        "LOCAL-ZJ-DEMO-TEXT",
        "LOCAL-SH-CONSTRUCTION-EVALUATION-2024",
        "LOCAL-HB-BID-SEPARATION-2026"
      ],
      "gap_action": "补每类评标方法的依据 seed 和至少一个样本文本 seed。"
    },
    {
      "requirement_id": "REQ-CANDIDATE-SHAPES",
      "dimension": "candidate_shape",
      "minimum_seed_count": 4,
      "required_tags_or_modes": [
        "ranked_candidates",
        "bid_separation_candidates",
        "unranked_candidates",
        "single_winner"
      ],
      "basis_refs": ["BASIS-TENDER-IMPLEMENTATION", "BASIS-PUBLICATION-10"],
      "gap_action": "补候选人排序、排名不分先后、定标候选、单中标人结果公告样本。"
    },
    {
      "requirement_id": "REQ-DOCUMENT-LIFECYCLE",
      "dimension": "document_lifecycle",
      "minimum_seed_count": 5,
