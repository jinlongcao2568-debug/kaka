      "basis_refs": ["BASIS-TENDER-LAW", "BASIS-PUBLICATION-10"],
      "gap_action": "补招标文件、候选人公示、结果公告、澄清答疑样本。"
    },
    {
      "requirement_id": "REQ-BRIGHT-DARK-BID",
      "dimension": "bright_dark_bid",
      "minimum_seed_count": 2,
      "required_tags_or_markers": ["dark_bid", "bright_bid"],
      "basis_refs": ["LOCAL-ZJ-DEMO-TEXT"],
