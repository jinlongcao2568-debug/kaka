  "source_documents": [
    "docs/L0.md",
    "docs/D10_订单支付交付与治理反馈规范.md",
    "docs/D11_测试验收与金标回归清单.md"
  ],
  "current_state": "INTERNAL_V0_ACTIVE",
  "contract_state": "FORMAL_CONTRACT_ACTIVE",
  "runtime_executor_enabled": true,
  "typed_writeback_supported": true,
  "governed_target_accumulation_supported": true,
  "mutation_mode": "ADDITIVE_INTERNAL_ONLY",
  "live_target_persistence_enabled": false,
  "formal_targets": [
    "project_fact",
    "saleable_opportunity",
    "contact_target",
    "review_queue_profile"
  ],
  "contract_semantics": {
    "outcome_targets_authoritative": true,
    "governance_targets_additive_only": true,
    "payment_exception_targets_additive_only": true,
    "delivery_exception_targets_additive_only": true,
    "silent_override_outcome_targets_forbidden": true,
    "projected_mutations_internal_only": true,
    "direct_target_persistence_blocked": true,
    "projected_only_targets_do_not_persist": true,
    "advisory_targets_are_trace_only": true,
    "persisted_targets_remain_internal_only": true,
    "upstream_feedback_projected_targets_contract_only": true,
    "service_local_target_semantics_forbidden": true
  },
  "target_semantic_groups": {
    "projected_only_targets": [
      "project_fact",
      "saleable_opportunity",
      "contact_target",
      "review_queue_profile",
      "sales_lead",
      "report_record"
    ],
    "persisted_targets": [
      "order_record",
      "payment_record",
      "delivery_record",
      "opportunity_outcome_event",
      "governance_feedback_event"
    ],
    "advisory_targets": [
      "buyer_fit",
      "challenger_candidate_profile",
      "outreach_plan"
    ],
    "trace_only_governance_targets": [
      "controlled_exception_record",
      "release_gates"
    ]
  },
  "target_source_resolution_order": [
    "outcome_taxonomy",
    "upstream_feedback_loop",
    "governance_taxonomy",
    "payment_exception",
    "delivery_exception"
  ],
  "additive_sources_allowed_targets": {
    "upstream_feedback_loop": [
      "sales_lead",
      "report_record",
      "buyer_fit",
      "challenger_candidate_profile"
    ],
    "governance_taxonomy": [
      "project_fact",
      "contact_target",
      "review_queue_profile",
      "order_record",
      "payment_record",
      "delivery_record",
      "governance_feedback_event",
      "controlled_exception_record",
      "release_gates",
      "outreach_plan"
    ],
    "payment_exception": [
      "project_fact",
      "saleable_opportunity",
      "order_record",
      "delivery_record"
    ],
    "delivery_exception": [
      "project_fact",
      "saleable_opportunity",
      "delivery_record"
    ]
  },
  "silent_override_forbidden_pairs": [
    {
      "base_source": "outcome_taxonomy",
      "additive_source": "governance_taxonomy",
      "rule": "governance_taxonomy may append targets only; it may not replace outcome base targets"
    },
    {
      "base_source": "outcome_taxonomy",
      "additive_source": "payment_exception",
      "rule": "payment_exception may append targets only; it may not replace outcome base targets"
    },
    {
      "base_source": "outcome_taxonomy",
      "additive_source": "delivery_exception",
      "rule": "delivery_exception may append targets only; it may not replace outcome base targets"
    },
    {
      "base_source": "outcome_taxonomy",
      "additive_source": "upstream_feedback_loop",
      "rule": "upstream feedback targets must stay in resolved_effective_writeback_targets and never backflow into outcome_writeback_targets"
    }
  ],
  "upstream_feedback_loop_contract": {
    "contract_ref": "contracts/sales/opportunity_policy_catalog.json#policies.opportunity_outcome_writeback_v1",
    "projected_targets_field": "upstream_feedback_projected_targets",
    "advisory_targets_field": "upstream_feedback_advisory_targets",
    "merge_semantics": "PROJECTED_FEEDBACK_ONLY",
    "projected_target_semantics": "PROJECTED_MUTATION_ONLY",
    "advisory_target_semantics": "TRACE_ONLY_CONTRACT",
    "direct_persistence_forbidden": true
  },
  "writeback_source_contracts": {
    "outcome_taxonomy": {
      "contract_ref": "contracts/sales/outcome_taxonomy_catalog.json",
      "source_output_field": "outcome_writeback_targets",
      "merge_semantics": "AUTHORITATIVE_BASE",
      "persisted_stage9_record_target": "opportunity_outcome_event",
      "silent_override_forbidden": true,
      "target_semantics": "BASE_TARGET_SET",
      "authoritative_feedback_contract_ref": "contracts/sales/opportunity_policy_catalog.json#policies.opportunity_outcome_writeback_v1"
    },
    "upstream_feedback_loop": {
      "contract_ref": "contracts/sales/opportunity_policy_catalog.json#policies.opportunity_outcome_writeback_v1",
      "source_output_field": "upstream_feedback_projected_targets + upstream_feedback_advisory_targets",
      "merge_semantics": "PROJECTED_FEEDBACK_ONLY",
      "persisted_stage9_record_target": "opportunity_outcome_event",
      "silent_override_forbidden": true,
      "target_semantics": "PROJECTED_CONTRACT_ONLY + TRACE_ONLY_ADVISORY"
    },
    "governance_taxonomy": {
      "contract_ref": "contracts/sales/governance_feedback_policy_catalog.json",
      "source_output_field": "governance_writeback_targets_optional",
      "merge_semantics": "ADDITIVE_ONLY",
      "persisted_stage9_record_target": "governance_feedback_event",
      "silent_override_forbidden": true,
      "target_semantics": "ADDITIVE_GOVERNED_TARGETS"
    },
    "payment_exception": {
      "contract_ref": "contracts/sales/payment_exception_catalog.json",
      "source_output_field": "payment_exception_writeback_targets_optional",
      "merge_semantics": "ADDITIVE_ONLY",
      "persisted_stage9_record_target": "payment_record",
      "silent_override_forbidden": true,
      "target_semantics": "ADDITIVE_EXCEPTION_TARGETS"
    },
    "delivery_exception": {
      "contract_ref": "contracts/sales/delivery_exception_catalog.json",
      "source_output_field": "delivery_exception_writeback_targets_optional",
      "merge_semantics": "ADDITIVE_ONLY",
      "persisted_stage9_record_target": "delivery_record",
      "silent_override_forbidden": true,
      "target_semantics": "ADDITIVE_EXCEPTION_TARGETS"
    }
  },
