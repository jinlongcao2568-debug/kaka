  "rules": [
    {
      "rule_id": "IMPACT-WON-OPPORTUNITY-001",
      "match": {
        "outcome_family": [
          "WON"
        ]
      },
      "target": "saleable_opportunity",
      "field_patches": {
        "saleability_status": "CLOSED",
        "crm_owner_state": "CLOSED"
      },
      "append_lists": {
        "blocking_reasons": [
          "OUTCOME_WON"
        ]
      },
      "effect_summary": "close opportunity after positive outcome"
    },
    {
      "rule_id": "IMPACT-WON-FACT-001",
      "match": {
        "outcome_family": [
          "WON"
        ]
      },
      "target": "project_fact",
      "field_patches": {
        "sale_gate_status": "HOLD",
        "delivery_risk_state": "ALLOW"
      },
      "append_lists": {
        "clue_summary": [
          "OUTCOME_WON"
        ],
        "risk_summary": [
          "NO_FURTHER_ACTION"
        ]
      },
      "effect_summary": "move fact chain to post-win hold"
    },
    {
      "rule_id": "IMPACT-LOST-OPPORTUNITY-001",
      "match": {
        "outcome_family": [
          "LOST"
        ]
      },
      "target": "saleable_opportunity",
      "field_patches": {
        "saleability_status": "BLOCKED"
      },
      "append_lists": {
        "blocking_reasons": [
          "OUTCOME_LOST"
        ]
      },
      "effect_summary": "block opportunity after lost outcome"
    },
    {
      "rule_id": "IMPACT-LOST-FACT-001",
      "match": {
        "outcome_family": [
          "LOST"
        ]
      },
      "target": "project_fact",
      "field_patches": {
        "sale_gate_status": "REVIEW"
      },
      "append_lists": {
        "risk_summary": [
          "OUTCOME_LOST_RESCORING_REQUIRED"
        ]
      },
      "effect_summary": "require fact refresh after loss"
    },
    {
      "rule_id": "IMPACT-WINDOW-MISSED-FACT-001",
      "match": {
        "outcome_family": [
          "WINDOW_MISSED"
        ]
      },
      "target": "project_fact",
      "field_patches": {
        "sale_gate_status": "HOLD"
      },
      "append_lists": {
        "clue_summary": [
          "WINDOW_MISSED"
        ]
      },
      "effect_summary": "hold fact chain and record window miss"
    },
    {
      "rule_id": "IMPACT-WINDOW-MISSED-QUEUE-001",
      "match": {
        "outcome_family": [
          "WINDOW_MISSED"
        ]
      },
      "target": "review_queue_profile",
      "field_patches": {
        "review_queue_bucket": "CRITICAL_WINDOW",
        "window_risk_level": "CRITICAL",
        "commercial_urgency_level": "CRITICAL",
        "review_priority_score": 100
      },
      "effect_summary": "reprioritize review queue after window miss"
    },
    {
      "rule_id": "IMPACT-WINDOW-MISSED-LEAD-001",
      "match": {
        "outcome_family": [
          "WINDOW_MISSED"
        ]
      },
      "target": "sales_lead",
      "field_patches": {
        "lead_status": "REVIEW"
      },
      "append_lists": {
        "status_reasons": [
          "WINDOW_MISSED"
        ]
      },
      "effect_summary": "re-qualify lead after window miss"
    },
    {
      "rule_id": "IMPACT-WINDOW-MISSED-REPORT-001",
      "match": {
        "outcome_family": [
          "WINDOW_MISSED"
        ]
      },
      "target": "report_record",
      "field_patches": {
        "report_status": "REVIEW_REQUIRED"
      },
      "append_lists": {
        "refresh_reasons": [
          "WINDOW_MISSED"
        ]
      },
      "effect_summary": "mark report record stale after window miss"
    },
    {
      "rule_id": "IMPACT-WINDOW-MISSED-BUYER-FIT-001",
      "match": {
        "outcome_family": [
          "WINDOW_MISSED"
        ]
      },
      "target": "buyer_fit",
      "field_patches": {
        "fit_refresh_required": true,
        "fit_refresh_reason": "WINDOW_MISSED"
      },
      "effect_summary": "refresh buyer fit after window miss"
    },
    {
      "rule_id": "IMPACT-CONTACT-FAILED-NO-RESPONSE-001",
      "match": {
        "outcome_family": [
          "CONTACT_FAILED"
        ],
        "feedback_reason": [
          "NO_RESPONSE"
        ]
      },
      "target": "contact_target",
      "field_patches": {
        "contact_target_status": "REVIEW_REQUIRED",
        "requires_manual_review": true
      },
      "append_lists": {
        "blocking_reasons": [
          "CONTACT_FAILED_NO_RESPONSE"
        ]
      },
      "effect_summary": "reselect contact after no response"
    },
    {
      "rule_id": "IMPACT-CONTACT-FAILED-INVALID-001",
      "match": {
        "outcome_family": [
          "CONTACT_FAILED"
        ],
        "feedback_reason": [
          "INVALID_CONTACT"
        ]
      },
      "target": "contact_target",
      "field_patches": {
        "contact_target_status": "INVALID",
        "requires_manual_review": true
      },
      "append_lists": {
        "blocking_reasons": [
          "CONTACT_FAILED_INVALID_CONTACT"
        ]
      },
      "effect_summary": "invalidate contact after invalid response"
    },
    {
      "rule_id": "IMPACT-CONTACT-FAILED-WRONG-ROLE-001",
      "match": {
        "outcome_family": [
          "CONTACT_FAILED"
        ],
        "feedback_reason": [
          "WRONG_ROLE"
        ]
      },
      "target": "contact_target",
      "field_patches": {
        "contact_target_status": "INVALID",
        "requires_manual_review": true,
        "contact_conflict_flag": true,
        "contact_conflict_reason": "wrong_role_reselect_required"
      },
      "append_lists": {
        "blocking_reasons": [
          "CONTACT_FAILED_WRONG_ROLE"
        ]
      },
      "effect_summary": "force reselect when role is wrong"
    },
    {
      "rule_id": "IMPACT-CONTACT-FAILED-OPTED-OUT-001",
      "match": {
        "outcome_family": [
          "CONTACT_FAILED"
        ],
        "feedback_reason": [
          "OPTED_OUT"
        ]
      },
      "target": "contact_target",
      "field_patches": {
        "contact_target_status": "BLOCKED",
        "requires_manual_review": true
      },
      "append_lists": {
        "blocking_reasons": [
          "CONTACT_FAILED_OPTED_OUT"
        ]
      },
      "effect_summary": "block future touch after opt-out"
    },
    {
      "rule_id": "IMPACT-CONTACT-FAILED-OPPORTUNITY-001",
      "match": {
        "outcome_family": [
          "CONTACT_FAILED"
        ]
      },
      "target": "saleable_opportunity",
      "field_patches": {
        "saleability_status": "RESTRICTED"
      },
      "append_lists": {
        "blocking_reasons": [
          "CONTACT_RESELECT_REQUIRED"
        ]
      },
      "effect_summary": "restrict opportunity pending contact reselection"
    },
    {
      "rule_id": "IMPACT-CONTACT-FAILED-LEAD-001",
      "match": {
        "outcome_family": [
          "CONTACT_FAILED"
        ]
      },
      "target": "sales_lead",
      "field_patches": {
        "lead_status": "REVIEW"
      },
      "append_lists": {
        "status_reasons": [
          "CONTACT_FAILED"
        ]
      },
      "effect_summary": "re-qualify sales lead after contact failure"
    },
    {
      "rule_id": "IMPACT-CONTACT-FAILED-REPORT-001",
      "match": {
        "outcome_family": [
          "CONTACT_FAILED"
        ]
      },
      "target": "report_record",
      "field_patches": {
        "report_status": "REVIEW_REQUIRED"
      },
      "append_lists": {
        "refresh_reasons": [
          "CONTACT_FAILED"
        ]
      },
      "effect_summary": "re-open report guidance after contact failure"
    },
    {
      "rule_id": "IMPACT-FALSE-POSITIVE-FACT-001",
      "match": {
        "outcome_family": [
          "FALSE_POSITIVE"
        ]
      },
      "target": "project_fact",
      "field_patches": {
        "sale_gate_status": "REVIEW",
        "competitor_quality_grade": "D"
      },
      "append_lists": {
        "risk_summary": [
          "FALSE_POSITIVE_REVIEW_REQUIRED"
        ]
      },
      "effect_summary": "downgrade fact confidence after false positive"
    },
    {
      "rule_id": "IMPACT-FALSE-POSITIVE-LEAD-001",
      "match": {
        "outcome_family": [
          "FALSE_POSITIVE"
        ]
      },
      "target": "sales_lead",
      "field_patches": {
        "lead_status": "DISQUALIFIED"
